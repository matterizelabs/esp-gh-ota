menu "ESP GitHub OTA"

    config ESP_GH_OTA_RECV_TIMEOUT
        int "OTA receive timeout (ms)"
        default 30000
        help
            Maximum time for reception of the firmware image over HTTPS.

    config ESP_GH_OTA_BUF_SIZE
        int "OTA buffer size (bytes)"
        default 1024
        range 1024 65536
        help
            Buffer size for OTA data transfers in bytes.

    config ESP_GH_OTA_POLL_INTERVAL_SEC
        int "Default poll interval (seconds)"
        default 300
        range 60 86400
        help
            How often to check GitHub for new releases, in seconds.
            Default: 300 (5 minutes). Minimum: 60 (1 minute).

    config ESP_GH_OTA_DEFAULT_OWNER
        string "Default GitHub owner/org"
        default ""
        help
            Default GitHub username or organization. Can be changed at
            runtime via the HTTP API (POST /api/config).

    config ESP_GH_OTA_DEFAULT_REPO
        string "Default GitHub repository"
        default ""
        help
            Default GitHub repository name. Can be changed at runtime
            via the HTTP API (POST /api/config).

    config ESP_GH_OTA_ENABLE_PARTIAL_DOWNLOAD
        bool "Enable partial HTTP download"
        default n
        select ESP_HTTPS_OTA_ENABLE_PARTIAL_DOWNLOAD
        select ESP_TLS_CLIENT_SESSION_TICKETS
        help
            Download the firmware image over multiple HTTP Range requests.
            Useful when the TLS in-content length is smaller than the image.

    config ESP_GH_OTA_PARTIAL_REQUEST_SIZE
        int "Partial HTTP request size (bytes)"
        default MBEDTLS_SSL_IN_CONTENT_LEN
        depends on ESP_GH_OTA_ENABLE_PARTIAL_DOWNLOAD
        help
            Number of bytes downloaded in a single HTTP request.

    config ESP_GH_OTA_ENABLE_RESUMPTION
        bool "Enable OTA resumption"
        default n
        select ESP_HTTPS_OTA_ENABLE_RESUMPTION
        help
            Resume the OTA download from where it left off after a reboot.
            Tracks bytes written and the asset URL in NVS.

    config ESP_GH_OTA_API_KEY
        string "Pre-shared API key for /api/config"
        default ""
        help
            When non-empty, the HTTP config endpoint (GET and POST
            /api/config) requires an X-API-Key header matching this
            value. Leave empty to disable authentication — the config
            API is then open on the LAN.

            Set this in sdkconfig.secrets (gitignored) so the key is
            not committed to version control.

endmenu
